rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User root document ──────────────────────────────────────────────────
    // Stores display name, email, createdAt.
    // Only the authenticated owner can read/write.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ── Notes subcollection ──────────────────────────────────────────────
      // Document ID: YYYY-MM-DD (Bikram Sambat date)
      // Value: { notes: Note[], updatedAt: number }
      match /notes/{dateId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete:      if request.auth != null && request.auth.uid == userId;
      }

      // ── Challenges document ──────────────────────────────────────────────
      // Single document "challenges" under the user root.
      // Value: { challenges: Challenge[], updatedAt: number }
      match /challenges {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Challenge completions subcollection ──────────────────────────────
      // Document ID: YYYY-MM-DD (Bikram Sambat date)
      // Value: { completions: Record<string,boolean>, updatedAt: number }
      match /challenge-completions/{dateId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete:      if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny all other reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
